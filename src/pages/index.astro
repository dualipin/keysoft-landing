---
import Layout from "../layouts/Layout.astro";
import logo from "../assets/logos/logo512.webp";
import { ArrowRight, Mail, MapPin, Phone, Quote, Star } from "@lucide/astro";
import { COMPANY_NAME } from "../constants/site";

type Skill = {
  name: string;
  level: number;
};

type SkillGroup = {
  title: string;
  items: Skill[];
};

type Project = {
  title: string;
  description: string;
  image: string;
  tags: string[];
};

type Service = {
  title: string;
  description: string;
};

type Testimonial = {
  name: string;
  role: string;
  quote: string;
};

const skillGroups: SkillGroup[] = [
  {
    title: "Lenguajes de Programacion",
    items: [
      { name: "C#", level: 95 },
      { name: "Python", level: 90 },
      { name: "JavaScript", level: 88 },
      { name: "SQL", level: 85 },
    ],
  },
  {
    title: "Tecnologias y Frameworks",
    items: [
      { name: ".NET", level: 95 },
      { name: ".NET MAUI", level: 90 },
      { name: "ASP.NET", level: 88 },
      { name: "SQL Server", level: 85 },
    ],
  },
  {
    title: "Herramientas",
    items: [
      { name: "Visual Studio", level: 95 },
      { name: "Git y GitHub", level: 90 },
      { name: "Diseno de BD", level: 88 },
    ],
  },
];

const projects: Project[] = [
  {
    title: "Aplicacion movil en .NET MAUI",
    description:
      "App con navegacion por pestanas que integra calculadora de area y perimetro con experiencia fluida.",
    image:
      "https://images.unsplash.com/photo-1556740738-b6a63e27c4df?auto=format&fit=crop&w=1200&q=80",
    tags: ["C#", ".NET MAUI", "XAML"],
  },
  {
    title: "Sistema de Gestion Inteligente de Trafico",
    description:
      "Plataforma para documentacion y analisis de datos orientada a optimizar la gestion del trafico vehicular.",
    image:
      "https://images.unsplash.com/photo-1555949963-aa79dcee981c?auto=format&fit=crop&w=1200&q=80",
    tags: ["Python", "SQL Server", "Analisis de Datos"],
  },
  {
    title: "Sistema de Gestion Empresarial",
    description:
      "Solucion web para inventarios, ventas y reportes con paneles dinamicos y trazabilidad operativa.",
    image:
      "https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&w=1200&q=80",
    tags: ["ASP.NET", "C#", "SQL Server"],
  },
  {
    title: "API REST para E-commerce",
    description:
      "Backend robusto para catalogo, carrito y ordenes con enfoque en escalabilidad y seguridad.",
    image:
      "https://images.unsplash.com/photo-1518773553398-650c184e0bb3?auto=format&fit=crop&w=1200&q=80",
    tags: [".NET", "API REST", "SQL"],
  },
];

const services: Service[] = [
  {
    title: "Desarrollo de aplicaciones moviles multiplataforma",
    description:
      "Apps nativas y multiplataforma con .NET MAUI, enfocadas en rendimiento, escalabilidad y UX cuidada.",
  },
  {
    title: "Desarrollo de sistemas personalizados",
    description:
      "Construccion de soluciones a la medida para procesos internos, operaciones y crecimiento del negocio.",
  },
  {
    title: "Diseno e implementacion de bases de datos",
    description:
      "Modelado relacional y optimizacion de consultas para garantizar integridad, velocidad y confiabilidad.",
  },
  {
    title: "Mantenimiento y mejora de software existente",
    description:
      "Refactorizacion y modernizacion de aplicaciones para reducir deuda tecnica y mejorar estabilidad.",
  },
  {
    title: "Asesoria en proyectos academicos de programacion",
    description:
      "Mentoria practica para aterrizar conceptos complejos en entregables reales y funcionales.",
  },
];

const testimonials: Testimonial[] = [
  {
    name: "Carlos Mendez",
    role: "Aplicacion movil empresarial",
    quote:
      "Excelente equipo de desarrollo. Entregaron antes del tiempo estimado y con gran calidad tecnica.",
  },
  {
    name: "Ana Rodriguez",
    role: "Proyecto academico universitario",
    quote:
      "Servicio profesional y responsable. Nos ayudaron a completar el sistema con resultados por encima de lo esperado.",
  },
  {
    name: "Roberto Sanchez",
    role: "Sistema de gestion empresarial",
    quote:
      "El sistema optimizo nuestros procesos. Recomendamos su trabajo por detalle tecnico y comunicacion clara.",
  },
];
---

<Layout>
  <main class="relative overflow-hidden bg-base-200">
    <div aria-hidden="true" class="pointer-events-none absolute inset-0">
      <div
        class="absolute inset-0 bg-[radial-gradient(circle_at_20%_10%,oklch(68%_0.21_40/0.2),transparent_42%),radial-gradient(circle_at_85%_50%,oklch(55%_0.16_250/0.18),transparent_46%),radial-gradient(circle_at_20%_90%,oklch(55%_0.16_250/0.16),transparent_38%)]"
      >
      </div>
      <div
        class="absolute inset-0 opacity-25 bg-[linear-gradient(oklch(92%_0.01_255/0.08)_1px,transparent_1px),linear-gradient(90deg,oklch(92%_0.01_255/0.08)_1px,transparent_1px)] bg-size-[38px_38px]"
      >
      </div>
    </div>

    <section
      id="inicio"
      class="hero relative min-h-screen px-4 pb-16 pt-28 sm:px-8 md:px-16 lg:px-24"
    >
      <div
        class="hero-content z-10 w-full max-w-7xl flex-col items-stretch gap-14 px-0"
      >
        <div class="grid items-center gap-10 lg:grid-cols-2">
          <div class="animate-fade-in-down space-y-6 animate-delay-[120ms]">
            <div
              class="badge badge-outline badge-lg gap-2 border-primary/40 bg-base-100/60 px-4 py-4"
            >
              <span class="inline-flex h-2 w-2 rounded-full bg-primary"></span>
              Disponible para proyectos
            </div>

            <h1
              class="text-5xl font-black uppercase leading-[0.95] sm:text-6xl lg:text-7xl"
            >
              Innovar.<br />
              Desarrollar.<br />
              <span class="text-primary">Crecer.</span>
            </h1>

            <p class="max-w-2xl text-lg text-base-content/80">
              <span class="font-semibold text-primary"
                >{COMPANY_NAME} - Compania de Software</span
              >
              <br />
              Soluciones tecnologicas modernas para un mundo conectado. Equipo especialista
              en
              <span class="font-semibold text-base-content"
                >Python, JavaScript, C# y .NET</span
              >
              para software confiable, escalable y de alto rendimiento.
            </p>

            <div class="flex flex-wrap items-center gap-4">
              <a
                href="#proyectos"
                class="btn btn-primary btn-lg animate-fade-in-down animate-delay-[240ms]"
                >Ver proyectos</a
              >
              <a
                href="#contacto"
                class="btn btn-outline btn-lg animate-fade-in-down animate-delay-[320ms]"
                >Contactar ahora</a
              >
            </div>

            <div class="grid gap-3 sm:grid-cols-2">
              <div
                class="badge badge-outline h-12 justify-start gap-2 border-base-content/20 bg-base-100/60 px-4 text-sm"
              >
                <MapPin class="size-4" />
                Tabasco, Mexico
              </div>
              <div
                class="badge badge-outline h-12 justify-start gap-2 border-base-content/20 bg-base-100/60 px-4 text-sm"
              >
                <Mail class="size-4" />
                contacto@tudominio.com
              </div>
              <div
                class="badge badge-outline h-12 justify-start gap-2 border-base-content/20 bg-base-100/60 px-4 text-sm sm:col-span-2"
              >
                <Phone class="size-4" />
                +52 0000000000
              </div>
            </div>
          </div>

          <div class="relative flex items-center justify-center lg:justify-end">
            <div
              class="card w-full max-w-sm animate-fade-in-down border border-base-content/10 bg-base-100/70 shadow-2xl backdrop-blur animate-delay-[180ms]"
            >
              <div class="card-body items-center p-7 sm:p-9">
                <div
                  class="rounded-box bg-base-100 p-5 shadow-inner shadow-primary/25 ring-1 ring-primary/20"
                >
                  <img
                    src={logo.src}
                    alt="Logo principal"
                    class="h-36 w-36 object-contain"
                  />
                </div>
                <div class="badge badge-primary badge-outline mt-4">
                  Software Engineering
                </div>
              </div>
            </div>

            <div
              class="badge badge-neutral absolute left-4 top-10 animate-fade-in-down animate-delay-[420ms]"
            >
              .NET & C#
            </div>
            <div
              class="badge badge-neutral absolute -right-1 top-28 animate-fade-in-down animate-delay-[520ms] sm:right-8"
            >
              .NET MAUI
            </div>
            <div
              class="badge badge-neutral absolute right-4 top-48 animate-fade-in-down animate-delay-[620ms]"
            >
              Python
            </div>
            <div
              class="badge badge-neutral absolute left-4 bottom-14 animate-fade-in-down animate-delay-[720ms]"
            >
              SQL Server
            </div>
          </div>
        </div>

        <div
          class="stats stats-vertical w-full animate-fade-in-down bg-base-100/65 shadow xl:stats-horizontal"
        >
          <div class="stat place-items-center">
            <div class="stat-value text-primary">3+</div>
            <div class="stat-title">Anos de experiencia</div>
          </div>

          <div class="stat place-items-center">
            <div class="stat-value text-primary">15+</div>
            <div class="stat-title">Proyectos completados</div>
          </div>

          <div class="stat place-items-center">
            <div class="stat-value text-primary">4</div>
            <div class="stat-title">Lenguajes dominados</div>
          </div>

          <div class="stat place-items-center">
            <div class="stat-value text-primary">100%</div>
            <div class="stat-title">Clientes satisfechos</div>
          </div>
        </div>
      </div>
    </section>

    <section
      id="sobre-nosotros"
      class="relative z-10 px-4 py-20 sm:px-8 md:px-16 lg:px-24"
    >
      <div class="mx-auto max-w-7xl space-y-8">
        <div
          class="badge badge-outline gap-2 border-primary/40 bg-base-100/60 px-4 py-4 text-primary"
        >
          Sobre nosotros
        </div>
        <div class="grid gap-8 lg:grid-cols-2">
          <article
            class="card border border-base-content/10 bg-base-100/65 shadow-xl"
          >
            <figure class="relative">
              <img
                src="https://images.unsplash.com/photo-1519085360753-af0119f7cbe7?auto=format&fit=crop&w=1200&q=80"
                alt="Equipo de desarrollo trabajando"
                class="h-full min-h-80 w-full object-cover"
              />
              <div class="absolute left-4 top-4 flex flex-col gap-2">
                <div class="badge badge-neutral">Programacion OOP</div>
                <div class="badge badge-neutral">.NET MAUI</div>
                <div class="badge badge-neutral">SQL Server</div>
                <div class="badge badge-neutral">Git & GitHub</div>
              </div>
              <div
                class="badge badge-primary badge-lg absolute bottom-4 right-4"
              >
                3+ anos de experiencia
              </div>
            </figure>
          </article>

          <article
            class="card border border-base-content/10 bg-base-100/65 shadow-xl"
          >
            <div class="card-body gap-5">
              <h2 class="text-4xl font-black leading-tight sm:text-5xl">
                {COMPANY_NAME} enfocado en <span class="text-primary"
                  >soluciones practicas</span
                >
              </h2>
              <p class="text-base-content/80">
                Somos una compania de software con experiencia en programacion
                orientada a objetos y desarrollo de aplicaciones utilizando
                tecnologias modernas como .NET y C#. Nos especializamos en la
                creacion de aplicaciones moviles multiplataforma con .NET MAUI y
                en el desarrollo de sistemas empresariales.
              </p>
              <p class="text-base-content/80">
                Nos enfocamos en construir soluciones practicas que optimicen
                procesos, mejoren la experiencia del usuario y aporten valor
                real a cada organizacion.
              </p>

              <div
                class="stats stats-vertical border border-base-content/10 bg-base-100 lg:stats-horizontal"
              >
                <div class="stat py-4">
                  <div class="stat-value text-primary text-3xl">15+</div>
                  <div class="stat-title">Proyectos</div>
                </div>
                <div class="stat py-4">
                  <div class="stat-value text-primary text-3xl">4</div>
                  <div class="stat-title">Lenguajes</div>
                </div>
                <div class="stat py-4">
                  <div class="stat-value text-primary text-3xl">100%</div>
                  <div class="stat-title">Satisfaccion</div>
                </div>
              </div>

              <div class="card-actions">
                <a href="#contacto" class="btn btn-primary">
                  Conversemos sobre tu proyecto
                  <ArrowRight class="size-4" />
                </a>
              </div>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section
      id="habilidades"
      class="relative z-10 px-4 py-20 sm:px-8 md:px-16 lg:px-24"
    >
      <div class="mx-auto max-w-7xl space-y-10">
        <div class="space-y-3 text-center">
          <div
            class="badge badge-outline gap-2 border-primary/40 bg-base-100/60 px-4 py-4 text-primary"
          >
            Habilidades
          </div>
          <h2 class="text-4xl font-black sm:text-5xl">
            Stack <span class="text-primary">Tecnologico</span>
          </h2>
        </div>

        <div class="space-y-8">
          {
            skillGroups.map((group) => (
              <article class="card border border-base-content/10 bg-base-100/65 shadow-xl">
                <div class="card-body gap-5">
                  <h3 class="card-title text-2xl">{group.title}</h3>
                  <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
                    {group.items.map((skill) => (
                      <div class="card border border-base-content/10 bg-base-100 shadow-sm">
                        <div class="card-body gap-2 p-4">
                          <h4 class="font-semibold text-lg">{skill.name}</h4>
                          <div class="flex items-center justify-between text-xs text-base-content/70">
                            <span>Dominio</span>
                            <span>{skill.level}%</span>
                          </div>
                          <progress
                            class="progress progress-primary h-2"
                            value={skill.level}
                            max="100"
                          />
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section
      id="proyectos"
      class="relative z-10 px-4 py-20 sm:px-8 md:px-16 lg:px-24"
    >
      <div class="mx-auto max-w-7xl space-y-8">
        <div class="flex flex-wrap items-end justify-between gap-4">
          <div class="space-y-3">
            <div
              class="badge badge-outline gap-2 border-primary/40 bg-base-100/60 px-4 py-4 text-primary"
            >
              Proyectos
            </div>
            <h2 class="text-4xl font-black sm:text-5xl">Trabajos Recientes</h2>
          </div>
          <a href="#contacto" class="link link-primary text-lg"
            >Ver todos los proyectos</a
          >
        </div>

        <div class="grid gap-6 lg:grid-cols-2">
          {
            projects.map((project) => (
              <article class="card border border-base-content/10 bg-base-100/70 shadow-xl">
                <figure>
                  <img
                    src={project.image}
                    alt={project.title}
                    class="h-56 w-full object-cover"
                  />
                </figure>
                <div class="card-body gap-4">
                  <div class="flex flex-wrap gap-2">
                    {project.tags.map((tag) => (
                      <span class="badge badge-outline border-primary/30 bg-base-100">
                        {tag}
                      </span>
                    ))}
                  </div>
                  <h3 class="card-title text-2xl">{project.title}</h3>
                  <p class="text-base-content/80">{project.description}</p>
                  <div class="card-actions justify-start">
                    <a class="btn btn-ghost text-primary">
                      Ver detalles <ArrowRight class="size-4" />
                    </a>
                  </div>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section
      id="servicios"
      class="relative z-10 px-4 py-20 sm:px-8 md:px-16 lg:px-24"
    >
      <div class="mx-auto max-w-7xl">
        <div class="grid gap-8 lg:grid-cols-[0.85fr_1.15fr]">
          <aside
            class="card h-fit border border-base-content/10 bg-base-100/65 shadow-xl"
          >
            <div class="card-body gap-5">
              <div
                class="badge badge-outline gap-2 border-primary/40 bg-base-100/60 px-4 py-4 text-primary"
              >
                Servicios
              </div>
              <h2 class="text-4xl font-black leading-tight sm:text-5xl">
                Que puede hacer {COMPANY_NAME} por tu empresa?
              </h2>
              <p class="text-base-content/80">
                Ofrecemos servicios de desarrollo de software profesional, desde
                aplicaciones moviles hasta sistemas empresariales complejos,
                siempre enfocados en calidad, resultados y eficiencia operativa.
              </p>
              <div class="card-actions">
                <a href="#contacto" class="btn btn-primary"
                  >Solicitar cotizacion</a
                >
              </div>
            </div>
          </aside>

          <div class="space-y-3">
            {
              services.map((service, index) => (
                <article class="card border border-base-content/10 bg-base-100/65 shadow-lg">
                  <div class="card-body flex-row items-start gap-5 p-6">
                    <div class="text-4xl font-black text-primary/55">
                      {String(index + 1).padStart(2, "0")}
                    </div>
                    <div class="space-y-2">
                      <h3 class="text-2xl font-bold leading-tight">
                        {service.title}
                      </h3>
                      <p class="text-base-content/80">{service.description}</p>
                    </div>
                  </div>
                </article>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <section
      id="testimonios"
      class="relative z-10 px-4 py-20 sm:px-8 md:px-16 lg:px-24"
    >
      <div class="mx-auto max-w-7xl space-y-8">
        <div class="space-y-3 text-center">
          <div
            class="badge badge-outline gap-2 border-primary/40 bg-base-100/60 px-4 py-4 text-primary"
          >
            Testimonios
          </div>
          <h2 class="text-4xl font-black sm:text-5xl">
            Lo que dicen nuestros clientes
          </h2>
          <div
            class="mx-auto flex w-fit items-center gap-2 rounded-box border border-primary/30 bg-base-100/70 px-4 py-2 text-sm"
          >
            <Star class="size-4 fill-primary text-primary" />
            <Star class="size-4 fill-primary text-primary" />
            <Star class="size-4 fill-primary text-primary" />
            <Star class="size-4 fill-primary text-primary" />
            <Star class="size-4 fill-primary text-primary" />
            <span class="font-semibold">4.9/5</span>
            <span class="text-base-content/70">Calificacion promedio</span>
          </div>
        </div>

        <div class="grid gap-6 lg:grid-cols-3">
          {
            testimonials.map((testimonial) => (
              <article class="card border border-base-content/10 bg-base-100/70 shadow-xl">
                <div class="card-body gap-4">
                  <div class="badge badge-outline border-primary/40 bg-base-100 p-3 text-primary">
                    <Quote class="size-4" />
                  </div>
                  <div class="flex gap-1 text-primary">
                    <Star class="size-4 fill-primary" />
                    <Star class="size-4 fill-primary" />
                    <Star class="size-4 fill-primary" />
                    <Star class="size-4 fill-primary" />
                    <Star class="size-4 fill-primary" />
                  </div>
                  <p class="text-base-content/80">"{testimonial.quote}"</p>
                  <div class="divider my-1" />
                  <div>
                    <h3 class="font-semibold">{testimonial.name}</h3>
                    <p class="text-sm text-base-content/70">
                      {testimonial.role}
                    </p>
                  </div>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section
      id="contacto"
      class="relative z-10 px-4 pb-20 pt-16 sm:px-8 md:px-16 lg:px-24"
    >
      <div class="mx-auto max-w-5xl space-y-8">
        <div class="space-y-3 text-center">
          <div
            class="badge badge-outline gap-2 border-primary/40 bg-base-100/60 px-4 py-4 text-primary"
          >
            Contacto
          </div>
          <h2 class="text-4xl font-black sm:text-5xl">
            Tienes un proyecto en mente?
          </h2>
          <p class="mx-auto max-w-2xl text-base-content/80">
            {COMPANY_NAME} esta disponible para colaborar en el desarrollo de soluciones
            tecnologicas adaptadas a tus objetivos de negocio.
          </p>
        </div>

        <div
          class="card border border-base-content/10 bg-base-100/70 shadow-2xl"
        >
          <div class="card-body gap-5 p-6 sm:p-10">
            <label class="form-control w-full gap-2">
              <span class="label-text">Nombre completo</span>
              <input
                type="text"
                placeholder="Tu nombre"
                class="input input-bordered w-full"
              />
            </label>

            <label class="form-control w-full gap-2">
              <span class="label-text">Correo electronico</span>
              <input
                type="email"
                placeholder="tu@email.com"
                class="input input-bordered w-full"
              />
            </label>

            <label class="form-control w-full gap-2">
              <span class="label-text">Mensaje</span>
              <textarea
                class="textarea textarea-bordered h-36 w-full"
                placeholder="Cuentame sobre tu proyecto..."></textarea>
            </label>

            <div class="card-actions flex-col gap-3 sm:flex-row">
              <button class="btn btn-primary flex-1">Enviar mensaje</button>
              <button class="btn btn-outline flex-1"
                >Iniciar sesion / Registrarse</button
              >
            </div>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-3">
          <div class="card border border-base-content/10 bg-base-100/65 shadow">
            <div class="card-body p-5">
              <Mail class="size-5 text-primary" />
              <h3 class="font-semibold">Email</h3>
              <p class="text-sm text-base-content/75">contacto@tudominio.com</p>
            </div>
          </div>
          <div class="card border border-base-content/10 bg-base-100/65 shadow">
            <div class="card-body p-5">
              <Phone class="size-5 text-primary" />
              <h3 class="font-semibold">Telefono</h3>
              <p class="text-sm text-base-content/75">+52 0000000000</p>
            </div>
          </div>
          <div class="card border border-base-content/10 bg-base-100/65 shadow">
            <div class="card-body p-5">
              <MapPin class="size-5 text-primary" />
              <h3 class="font-semibold">Ubicacion</h3>
              <p class="text-sm text-base-content/75">Tabasco, Mexico</p>
            </div>
          </div>
        </div>
