---
import SectionTitle from "../components/ui/SectionTitle.astro";
import SkillCard from "../components/common/SkillCard.astro";
import { skillGroups } from "../data/skills";
---

<section
  id="habilidades"
  class="relative z-10 px-4 py-20 sm:px-8 md:px-16 lg:px-24"
>
  <div class="mx-auto max-w-7xl space-y-10">
    <div data-animate="animate-fade-in-up">
      <SectionTitle label="Habilidades" title="Stack Tecnologico" />
    </div>

    <div class="space-y-8">
      {
        skillGroups.map((group, i) => (
          <div
            data-animate="animate-fade-in-up"
            data-animate-delay={`${i * 120}ms`}
          >
            <article class="card border border-base-content/10 bg-base-100/65 shadow-xl">
              <div class="card-body gap-5">
                <h3 class="card-title text-2xl">{group.title}</h3>
                <div class="grid gap-4 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
                  {group.items.map((skill) => (
                    <SkillCard skill={skill} />
                  ))}
                </div>
              </div>
            </article>
          </div>
        ))
      }
    </div>
  </div>
</section>
