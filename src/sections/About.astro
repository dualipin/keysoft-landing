---
import { COMPANY_NAME } from "../constants/site";
import { ArrowRight } from "@lucide/astro";
import SectionTitle from "../components/ui/SectionTitle.astro";
import Card from "../components/ui/Card.astro";
---

<section
  id="sobre-nosotros"
  class="relative z-10 px-4 py-20 sm:px-8 md:px-16 lg:px-24"
>
  <div class="mx-auto max-w-7xl space-y-8">
    <SectionTitle label="Sobre nosotros" title="Quienes somos" />

    <div class="grid gap-8 lg:grid-cols-2">
      <Card class="border border-base-content/10 bg-base-100/65 shadow-xl">
        <figure class="relative">
          <img
            src="https://images.unsplash.com/photo-1519085360753-af0119f7cbe7?auto=format&fit=crop&w=1200&q=80"
            alt="Equipo de desarrollo trabajando"
            class="h-full min-h-80 w-full object-cover"
          />
          <div class="absolute left-4 top-4 flex flex-col gap-2">
            <span class="badge badge-neutral">Programacion OOP</span>
            <span class="badge badge-neutral">.NET MAUI</span>
            <span class="badge badge-neutral">SQL Server</span>
            <span class="badge badge-neutral">Git & GitHub</span>
          </div>
          <div class="badge badge-primary badge-lg absolute bottom-4 right-4">
            3+ años de experiencia
          </div>
        </figure>
      </Card>

      <Card class="border border-base-content/10 bg-base-100/65 shadow-xl">
        <div class="card-body gap-5">
          <h2 class="text-4xl font-black leading-tight sm:text-5xl">
            {COMPANY_NAME} enfocado en <span class="text-primary"
              >soluciones practicas</span
            >
          </h2>
          <p class="text-base-content/80">
            Somos una compania de software con experiencia en programacion
            orientada a objetos y desarrollo de aplicaciones utilizando
            tecnologias modernas como .NET y C#. Nos especializamos en la
            creacion de aplicaciones moviles multiplataforma con .NET MAUI y en
            el desarrollo de sistemas empresariales.
          </p>
          <p class="text-base-content/80">
            Nos enfocamos en construir soluciones practicas que optimicen
            procesos, mejoren la experiencia del usuario y aporten valor real a
            cada organizacion.
          </p>

          <div
            class="stats stats-vertical border border-base-content/10 bg-base-100 lg:stats-horizontal"
          >
            <div class="stat py-4">
              <div class="stat-value text-primary text-3xl">15+</div>
              <div class="stat-title">Proyectos</div>
            </div>
            <div class="stat py-4">
              <div class="stat-value text-primary text-3xl">4</div>
              <div class="stat-title">Lenguajes</div>
            </div>
            <div class="stat py-4">
              <div class="stat-value text-primary text-3xl">100%</div>
              <div class="stat-title">Satisfaccion</div>
            </div>
          </div>

          <div class="card-actions">
            <a href="#contacto" class="btn btn-primary">
              Conversemos sobre tu proyecto
              <ArrowRight class="size-4" />
            </a>
          </div>
        </div>
      </Card>
    </div>
  </div>
</section>
