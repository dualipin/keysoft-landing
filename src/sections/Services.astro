---
import SectionTitle from "../components/ui/SectionTitle.astro";
import ServiceItem from "../components/common/ServiceItem.astro";
import { services } from "../data/services";
import { COMPANY_NAME } from "../constants/site";
---

<section
  id="servicios"
  class="relative z-10 px-4 py-20 sm:px-8 md:px-16 lg:px-24"
>
  <div class="mx-auto max-w-7xl">
    <div class="grid gap-8 grid-cols-1 lg:grid-cols-[0.85fr_1.15fr]">
      <div data-animate="animate-fade-in-left">
        <aside
          class="card h-fit border border-base-content/10 bg-base-100/65 shadow-xl"
        >
          <div class="card-body gap-5">
            <SectionTitle
              label="Servicios"
              title={`Que puede hacer ${COMPANY_NAME} por tu empresa?`}
            />
            <p class="text-base-content/80">
              Ofrecemos servicios de desarrollo de software profesional, desde
              aplicaciones moviles hasta sistemas empresariales complejos,
              siempre enfocados en calidad, resultados y eficiencia operativa.
            </p>
            <div class="card-actions">
              <a href="#contacto" class="btn btn-primary"
                >Solicitar cotizacion</a
              >
            </div>
          </div>
        </aside>
      </div>

      <div
        data-animate="animate-fade-in-right"
        data-animate-delay="150ms"
        class="space-y-3"
      >
        {
          services.map((service, index) => (
            <ServiceItem service={service} index={index} />
          ))
        }
      </div>
    </div>
  </div>
</section>
